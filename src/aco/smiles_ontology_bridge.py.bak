"""
Step 2: SMILES 특성 ↔ 온톨로지 노드 브릿지 매퍼

SMILES 데이터프레임의 특성 컬럼명(혹은 MolecularFeatureExtractor가 추출한
특성명)과 온톨로지 그래프 노드 라벨을 자동으로 매핑한다.

**핵심 전략: 시맨틱 서브그래프 주입 (Semantic Subgraph Injection)**

DTO(Drug Target Ontology)에는 분자 기술자(molecular descriptor) 개념 노드가
존재하지 않기 때문에, 기존 퍼지 매칭만으로는 Mapped 0이 발생한다.
이 모듈은 다음과 같은 시맨틱 계층 구조를 온톨로지 그래프에 주입하여
개미(Ant)가 실제 도메인 지식을 기반으로 특성 노드에 도달하도록 한다:

  Chemical entity (기존)
    └─ Molecular entity (기존)
         └─ molecular_descriptor (주입)
              ├─ physicochemical_property   → molecular_weight, logp, tpsa
              ├─ hydrogen_bonding           → num_hbd, num_hba
              ├─ structural_topology        → num_rotatable_bonds, num_rings,
              │                               num_aromatic_rings, fsp3
              └─ atomic_composition         → num_atoms, num_heavy_atoms,
                                              num_heteroatoms, num_carbons,
                                              num_oxygens, num_nitrogens,
                                              num_halogens

추가로 기존 온톨로지 노드와의 교차 연결(cross-link)을 생성하여
개미가 여러 경로를 통해 특성 노드에 도달할 수 있도록 한다.
"""

from __future__ import annotations

import logging
import re
from typing import Any, Callable, Dict, List, Optional, Set, Tuple

import networkx as nx
import pandas as pd

logger = logging.getLogger(__name__)

# ── 유사도 계산 ───────────────────────────────────────────────

try:
    from fuzzywuzzy import fuzz as _fuzz

    def _fuzzy_ratio(a: str, b: str) -> int:
        """fuzzywuzzy token_set_ratio 기반 유사도 (0‑100)."""
        return _fuzz.token_set_ratio(a.lower(), b.lower())

except ImportError:
    _fuzz = None  # type: ignore[assignment]

    def _fuzzy_ratio(a: str, b: str) -> int:  # type: ignore[misc]
        a_low, b_low = a.lower(), b.lower()
        if a_low == b_low:
            return 100
        if a_low in b_low or b_low in a_low:
            return 80
        ta, tb = set(re.split(r"[\W_]+", a_low)), set(re.split(r"[\W_]+", b_low))
        ta.discard("")
        tb.discard("")
        if not ta or not tb:
            return 0
        overlap = len(ta & tb) / max(len(ta | tb), 1)
        return int(overlap * 100)


# ── MolecularFeatureExtractor에서 추출 가능한 수치 특성 목록 ──

KNOWN_NUMERIC_FEATURES: Dict[str, List[str]] = {
    "molecular_weight": ["MolWt", "MW", "molecular_weight", "MolecularWeight"],
    "logp": ["LogP", "logP", "MolLogP", "CLogP", "logp"],
    "tpsa": ["TPSA", "tpsa", "TopologicalPolarSurfaceArea"],
    "num_hbd": ["NumHDonors", "HBD", "num_hbd", "HydrogenBondDonors"],
    "num_hba": ["NumHAcceptors", "HBA", "num_hba", "HydrogenBondAcceptors"],
    "num_rotatable_bonds": ["NumRotatableBonds", "RotBonds", "num_rotatable_bonds"],
    "num_rings": ["RingCount", "NumRings", "num_rings"],
    "num_aromatic_rings": ["NumAromaticRings", "AromaticRings", "num_aromatic_rings"],
    "num_atoms": ["NumAtoms", "num_atoms", "AtomCount"],
    "num_heavy_atoms": ["HeavyAtomCount", "num_heavy_atoms"],
    "molar_refractivity": ["MolarRefractivity", "MolMR", "molar_refractivity"],
    "n_plus_o_count": ["NOCount", "n_plus_o_count"],
    "num_heteroatoms": ["NumHeteroatoms", "num_heteroatoms"],
    "formal_charge": ["FormalCharge", "formal_charge"],
    "fsp3": ["FractionCSP3", "fsp3", "Fsp3"],
    "num_carbons": ["NumCarbons", "num_carbons", "CarbonCount"],
    "num_oxygens": ["NumOxygens", "num_oxygens", "OxygenCount"],
    "num_nitrogens": ["NumNitrogens", "num_nitrogens", "NitrogenCount"],
    "num_halogens": ["NumHalogens", "num_halogens", "HalogenCount"],
}

# 모든 동의어 → 정규화된 키 역매핑
_SYNONYM_TO_KEY: Dict[str, str] = {}
for _key, _syns in KNOWN_NUMERIC_FEATURES.items():
    for _syn in _syns:
        _SYNONYM_TO_KEY[_syn.lower()] = _key
    _SYNONYM_TO_KEY[_key.lower()] = _key


def _normalize_feature_name(name: str) -> Optional[str]:
    """특성명을 정규화된 키로 변환. 매칭 실패 시 None."""
    return _SYNONYM_TO_KEY.get(name.lower())


# ═════════════════════════════════════════════════════════════
# 시맨틱 서브그래프 정의 (Semantic Subgraph Definition)
# ═════════════════════════════════════════════════════════════

# 주입할 카테고리 노드 계층 구조
_SEMANTIC_CATEGORIES: Dict[str, Dict[str, Any]] = {
    "molecular_descriptor": {
        "label": "Molecular Descriptor",
        "uri": "urn:dto:molecular_descriptor",
        "parent": "Molecular entity",  # 기존 온톨로지 노드에 연결
        "description": "Quantitative molecular property computed from structure",
    },
    "physicochemical_property": {
        "label": "Physicochemical Property",
        "uri": "urn:dto:physicochemical_property",
        "parent": "molecular_descriptor",
        "description": "Properties related to physical chemistry (mass, polarity, partition)",
    },
    "hydrogen_bonding": {
        "label": "Hydrogen Bonding Capacity",
        "uri": "urn:dto:hydrogen_bonding",
        "parent": "molecular_descriptor",
        "description": "Hydrogen bond donor and acceptor counts",
    },
    "structural_topology": {
        "label": "Structural Topology",
        "uri": "urn:dto:structural_topology",
        "parent": "molecular_descriptor",
        "description": "Ring systems, rotatable bonds, sp3 fraction",
    },
    "atomic_composition": {
        "label": "Atomic Composition",
        "uri": "urn:dto:atomic_composition",
        "parent": "molecular_descriptor",
        "description": "Atom counts and elemental composition",
    },
}

# 각 기술자 → (카테고리, 시맨틱 라벨)
_DESCRIPTOR_TO_CATEGORY: Dict[str, Tuple[str, str]] = {
    # ── 물리화학적 성질 ──
    "molecular_weight": ("physicochemical_property", "Molecular Weight"),
    "logp": ("physicochemical_property", "Octanol-Water Partition Coefficient (LogP)"),
    "tpsa": ("physicochemical_property", "Topological Polar Surface Area (TPSA)"),
    # ── 수소 결합 ──
    "num_hbd": ("hydrogen_bonding", "Hydrogen Bond Donor Count"),
    "num_hba": ("hydrogen_bonding", "Hydrogen Bond Acceptor Count"),
    # ── 구조 위상 ──
    "num_rotatable_bonds": ("structural_topology", "Rotatable Bond Count"),
    "num_rings": ("structural_topology", "Ring Count"),
    "num_aromatic_rings": ("structural_topology", "Aromatic Ring Count"),
    "fsp3": ("structural_topology", "Fraction of sp3 Carbons (Fsp3)"),
    # ── 원자 조성 ──
    "num_atoms": ("atomic_composition", "Total Atom Count"),
    "num_heavy_atoms": ("atomic_composition", "Heavy Atom Count"),
    "num_heteroatoms": ("atomic_composition", "Heteroatom Count"),
    "num_carbons": ("atomic_composition", "Carbon Atom Count"),
    "num_oxygens": ("atomic_composition", "Oxygen Atom Count"),
    "num_nitrogens": ("atomic_composition", "Nitrogen Atom Count"),
    "num_halogens": ("atomic_composition", "Halogen Atom Count"),
    # ── 기타 (추가 특성이 들어올 경우 대비) ──
    "molar_refractivity": ("physicochemical_property", "Molar Refractivity"),
    "n_plus_o_count": ("atomic_composition", "Nitrogen + Oxygen Count"),
    "formal_charge": ("physicochemical_property", "Formal Charge"),
}

# 기존 온톨로지 노드와의 교차 연결 (cross-links)
# (source_injected_node, target_existing_node, predicate)
_CROSS_LINKS: List[Tuple[str, str, str]] = [
    # LogP ↔ Lipid (지질과 지용성은 밀접한 관계)
    ("feature:logp", "Lipid", "relatedTo"),
    # 수소 결합 ↔ Ion (이온 상호작용과 수소 결합)
    ("hydrogen_bonding", "Ion", "relatedTo"),
    # 물리화학 성질 ↔ quality (성질은 품질/속성)
    ("physicochemical_property", "quality", "relatedTo"),
    # 분자 기술자 ↔ Chemical entity (화학 엔티티의 기술자)
    ("molecular_descriptor", "Chemical entity", "describesEntityType"),
    # 구조 위상 ↔ Molecular entity (분자 구조)
    ("structural_topology", "Molecular entity", "relatedTo"),
    # 원자 조성 ↔ Molecular entity
    ("atomic_composition", "Molecular entity", "relatedTo"),
]


class SMILESOntologyBridge:
    """SMILES 특성과 온톨로지 그래프 노드 사이의 매핑 브릿지.

    시맨틱 서브그래프를 온톨로지에 주입하여
    각 분자 기술자가 도메인 지식 기반 계층 구조에 안착하도록 한다.

    Parameters
    ----------
    graph : nx.DiGraph
        OWLGraphBuilder.build()로 생성된 온톨로지 그래프.
    match_threshold : int
        퍼지 매칭 유사도 임계값 (0‑100). 기본 70.

    Attributes
    ----------
    mapped_features : dict[str, str]
        ``{feature_name: matched_node_id}`` 매핑 결과.
    """

    def __init__(
        self,
        graph: nx.DiGraph,
        match_threshold: int = 70,
    ) -> None:
        self.graph = graph
        self.match_threshold = match_threshold
        self.mapped_features: Dict[str, str] = {}

        # 노드 라벨 → 노드 ID 역인덱스
        self._label_to_node: Dict[str, str] = {}
        for nid, ndata in graph.nodes(data=True):
            label = ndata.get("label", nid)
            self._label_to_node[label.lower()] = nid

        # 시맨틱 서브그래프 주입 (카테고리 노드 + 교차 연결)
        self._inject_semantic_subgraph()

    # ── 시맨틱 서브그래프 주입 ─────────────────────────────────

    def _inject_semantic_subgraph(self) -> None:
        """온톨로지 그래프에 분자 기술자 카테고리 계층을 주입한다.

        이 메서드는 __init__에서 1회 호출되며, 다음을 수행한다:
        1) 카테고리 노드 생성 (molecular_descriptor, physicochemical_property, ...)
        2) 카테고리 간 subClassOf 엣지 생성
        3) 기존 온톨로지 노드와의 교차 연결 (cross-link) 생성

        카테고리 노드의 parent가 그래프에 존재하지 않으면
        최상위 노드(Thing)에 연결한다.
        """
        G = self.graph

        # hub 노드 탐지 (fallback)
        hub = None
        for hc in ("Thing", "thing", "owl:Thing"):
            if hc in G:
                hub = hc
                break
        if hub is None and G.number_of_nodes() > 0:
            hub = max(G.nodes, key=lambda n: G.degree(n))

        # 1) 카테고리 노드 생성 + 계층 연결
        injected_count = 0
        for cat_id, cat_info in _SEMANTIC_CATEGORIES.items():
            if cat_id not in G:
                G.add_node(
                    cat_id,
                    label=cat_info["label"],
                    uri=cat_info["uri"],
                    description=cat_info.get("description", ""),
                    is_semantic_category=True,
                )
                injected_count += 1

            # parent 연결 (subClassOf)
            parent = cat_info["parent"]
            if parent not in G:
                # parent가 없으면 hub에 연결
                parent = hub
            if parent and parent in G:
                # cat → parent (subClassOf 방향: cat is a subclass of parent)
                if not G.has_edge(cat_id, parent):
                    G.add_edge(
                        cat_id,
                        parent,
                        predicate="subClassOf",
                        pheromone=1.0,
                    )
                # 역방향도 추가하여 양방향 탐색 지원
                if not G.has_edge(parent, cat_id):
                    G.add_edge(
                        parent,
                        cat_id,
                        predicate="hasSubClass",
                        pheromone=1.0,
                    )

            # 라벨 인덱스 갱신
            self._label_to_node[cat_info["label"].lower()] = cat_id
            self._label_to_node[cat_id.lower()] = cat_id

        # 2) 교차 연결 (cross-links)
        cross_count = 0
        for src, tgt, pred in _CROSS_LINKS:
            if src in G and tgt in G:
                if not G.has_edge(src, tgt):
                    G.add_edge(src, tgt, predicate=pred, pheromone=1.0)
                    cross_count += 1
                if not G.has_edge(tgt, src):
                    G.add_edge(tgt, src, predicate=f"inv_{pred}", pheromone=1.0)
                    cross_count += 1

        logger.info(
            "Semantic subgraph injected: %d category nodes, %d cross-links",
            injected_count,
            cross_count,
        )

    # ── 공개 API ───────────────────────────────────────────────

    def auto_map(
        self,
        feature_names: List[str],
        *,
        extra_synonyms: Optional[Dict[str, List[str]]] = None,
    ) -> Dict[str, str]:
        """특성 이름 리스트를 온톨로지 노드와 자동 매핑한다.

        매핑 우선순위:
        0) **시맨틱 카테고리 매핑** (DESCRIPTOR_TO_CATEGORY 사전 기반)
           → 정규화된 이름이 사전에 있으면 해당 카테고리 아래에
             feature 노드를 생성하고 즉시 매핑. **항상 성공**.
        1) 정확히 일치하는 기존 노드가 있으면 해당 노드에 매핑.
        2) 부분 문자열 포함 여부 검사.
        3) 퍼지 매칭으로 임계값 이상인 최고 유사도 노드 선택.
        4) 위 모두 실패 시 molecular_descriptor 아래에 generic feature 노드 생성.

        Parameters
        ----------
        feature_names : list[str]
            SMILES 특성명 리스트.
        extra_synonyms : dict, optional
            추가 동의어 ``{feature_name: [synonym, ...]}``

        Returns
        -------
        dict[str, str]
            ``{feature_name: matched_node_id}``
        """
        G = self.graph

        for feat in feature_names:
            if feat in self.mapped_features:
                continue

            feat_lower = feat.lower()

            # 0) 시맨틱 카테고리 매핑 (최우선)
            norm = _normalize_feature_name(feat)
            lookup_key = norm if norm else feat_lower
            if lookup_key in _DESCRIPTOR_TO_CATEGORY:
                cat_id, sem_label = _DESCRIPTOR_TO_CATEGORY[lookup_key]
                nid = f"feature:{lookup_key}"
                self._create_semantic_feature_node(
                    nid, lookup_key, sem_label, cat_id, feat
                )
                continue

            # 1) 정확 일치 (기존 온톨로지 노드)
            if feat_lower in self._label_to_node:
                self._register(feat, self._label_to_node[feat_lower])
                continue

            # 1-b) 정규화된 키 동의어 → 노드 매칭
            if norm and norm.lower() in self._label_to_node:
                self._register(feat, self._label_to_node[norm.lower()])
                continue

            # extra_synonyms 확인
            if extra_synonyms and feat in extra_synonyms:
                matched = False
                for syn in extra_synonyms[feat]:
                    if syn.lower() in self._label_to_node:
                        self._register(feat, self._label_to_node[syn.lower()])
                        matched = True
                        break
                if matched:
                    continue

            # 2) 부분 문자열 포함
            node_labels = list(self._label_to_node.keys())
            best_substr: Optional[str] = None
            for nl in node_labels:
                if feat_lower in nl or nl in feat_lower:
                    best_substr = nl
                    break
            if best_substr:
                self._register(feat, self._label_to_node[best_substr])
                continue

            # 3) 퍼지 매칭
            best_score, best_node = 0, None
            for nl in node_labels:
                score = _fuzzy_ratio(feat, nl)
                if score > best_score:
                    best_score, best_node = score, nl
            if best_score >= self.match_threshold and best_node is not None:
                self._register(feat, self._label_to_node[best_node])
                logger.info(
                    "Fuzzy-matched '%s' -> '%s' (score=%d)",
                    feat,
                    best_node,
                    best_score,
                )
                continue

            # 4) 최종 폴백: molecular_descriptor 아래에 generic 노드 생성
            logger.info(
                "No ontology match for '%s' -> creating generic feature node",
                feat,
            )
            nid = f"feature:{feat_lower}"
            parent = "molecular_descriptor" if "molecular_descriptor" in G else None
            self._create_semantic_feature_node(
                nid, feat_lower, feat, parent or "molecular_descriptor", feat
            )

        return dict(self.mapped_features)

    def map_from_dataframe(
        self,
        df: pd.DataFrame,
        *,
        exclude_columns: Optional[Set[str]] = None,
    ) -> Dict[str, str]:
        """DataFrame 컬럼명을 온톨로지 노드와 자동 매핑한다.

        Parameters
        ----------
        df : pd.DataFrame
            SMILES 특성 데이터프레임.
        exclude_columns : set, optional
            매핑에서 제외할 컬럼명 집합 (예: ``{'smiles', 'label'}``).

        Returns
        -------
        dict[str, str]
        """
        exclude = exclude_columns or set()
        numeric_cols = [
            c for c in df.select_dtypes(include="number").columns
            if c not in exclude
        ]
        return self.auto_map(numeric_cols)

    def create_feature_nodes(
        self,
        feature_names: List[str],
        *,
        connect_to: Optional[str] = None,
    ) -> List[str]:
        """매핑되지 않은 특성에 대해 시맨틱 카테고리 기반 feature 노드를 생성한다.

        기존 매핑이 있으면 해당 노드에 속성만 추가한다.
        시맨틱 카테고리 매핑이 가능하면 카테고리 아래에 연결하고,
        불가능하면 molecular_descriptor 아래에 연결한다.

        Parameters
        ----------
        feature_names : list[str]
        connect_to : str | None
            지정하면 이 노드에 feature 노드를 연결. None이면 자동 카테고리 배정.

        Returns
        -------
        list[str]
            생성되거나 갱신된 feature 노드 ID 리스트.
        """
        created: List[str] = []
        for feat in feature_names:
            if feat in self.mapped_features:
                nid = self.mapped_features[feat]
                self.graph.nodes[nid]["is_feature"] = True
                self.graph.nodes[nid]["feature_key"] = feat
                created.append(nid)
                continue

            feat_lower = feat.lower()
            norm = _normalize_feature_name(feat)
            lookup = norm if norm else feat_lower

            # 시맨틱 카테고리 매핑 시도
            if lookup in _DESCRIPTOR_TO_CATEGORY:
                cat_id, sem_label = _DESCRIPTOR_TO_CATEGORY[lookup]
            else:
                cat_id = connect_to or "molecular_descriptor"
                sem_label = feat

            nid = f"feature:{lookup}"
            self._create_semantic_feature_node(nid, lookup, sem_label, cat_id, feat)
            created.append(nid)

        return created

    def get_split_condition(
        self,
        node_id: str,
        feature_series: pd.Series,
        *,
        strategy: str = "median",
    ) -> Optional[Dict[str, Any]]:
        """is_feature==True 노드에 도착한 개미가 분할 조건을 계산한다.

        Parameters
        ----------
        node_id : str
            그래프 노드 ID.
        feature_series : pd.Series
            해당 특성의 실제 수치 데이터.
        strategy : str
            분할 전략. ``"median"`` | ``"mean"`` | ``"quartile"``.

        Returns
        -------
        dict | None
            ``{"feature": ..., "operator": "<=", "threshold": float}``
            또는 feature 노드가 아니면 None.
        """
        ndata = self.graph.nodes.get(node_id)
        if ndata is None or not ndata.get("is_feature"):
            return None

        feat_key = ndata.get("feature_key", node_id)
        values = feature_series.dropna()

        if values.empty:
            return None

        if strategy == "median":
            threshold = float(values.median())
        elif strategy == "mean":
            threshold = float(values.mean())
        elif strategy == "quartile":
            threshold = float(values.quantile(0.5))
        else:
            threshold = float(values.median())

        return {
            "feature": feat_key,
            "operator": "<=",
            "threshold": threshold,
        }

    def print_mapping(self) -> None:
        """현재 매핑 상태를 출력한다."""
        print(f"[SMILESOntologyBridge] Mapped features: {len(self.mapped_features)}")
        for feat, nid in sorted(self.mapped_features.items()):
            is_feat = self.graph.nodes[nid].get("is_feature", False)
            cat = "?"
            # 카테고리 추적
            for _, parent, edata in self.graph.out_edges(nid, data=True):
                if edata.get("predicate") == "subClassOf" and self.graph.nodes.get(
                    parent, {}
                ).get("is_semantic_category"):
                    cat = parent
                    break
            print(f"  {feat:30s} -> {nid:40s} (cat={cat}, is_feature={is_feat})")

    def get_semantic_stats(self) -> Dict[str, Any]:
        """시맨틱 매핑 통계를 반환한다."""
        G = self.graph
        cats = {
            nid
            for nid in G.nodes()
            if G.nodes[nid].get("is_semantic_category")
        }
        feats = {
            nid
            for nid in G.nodes()
            if G.nodes[nid].get("is_feature")
        }
        cross = sum(
            1
            for u, v, d in G.edges(data=True)
            if d.get("predicate") in ("relatedTo", "inv_relatedTo",
                                       "describesEntityType", "inv_describesEntityType")
        )
        return {
            "semantic_categories": len(cats),
            "feature_nodes": len(feats),
            "cross_links": cross,
            "total_mapped": len(self.mapped_features),
        }

    # ── 내부 구현 ──────────────────────────────────────────────

    def _create_semantic_feature_node(
        self,
        node_id: str,
        feature_key: str,
        semantic_label: str,
        category_id: str,
        original_name: str,
    ) -> None:
        """시맨틱 카테고리 아래에 feature 노드를 생성하고 매핑 등록한다.

        Parameters
        ----------
        node_id : str
            그래프 노드 ID (예: "feature:logp")
        feature_key : str
            정규화된 특성 키 (예: "logp")
        semantic_label : str
            시맨틱 라벨 (예: "Octanol-Water Partition Coefficient (LogP)")
        category_id : str
            부모 카테고리 노드 ID (예: "physicochemical_property")
        original_name : str
            원본 특성명 (예: "logp")
        """
        G = self.graph

        if node_id not in G:
            G.add_node(
                node_id,
                label=semantic_label,
                uri=f"urn:smiles_feature:{feature_key}",
                is_feature=True,
                feature_key=feature_key,
                feature_name=original_name,
            )
        else:
            G.nodes[node_id]["is_feature"] = True
            G.nodes[node_id]["feature_key"] = feature_key
            G.nodes[node_id]["feature_name"] = original_name

        # 카테고리에 subClassOf 연결
        if category_id in G:
            if not G.has_edge(node_id, category_id):
                G.add_edge(
                    node_id,
                    category_id,
                    predicate="subClassOf",
                    pheromone=1.0,
                )
            if not G.has_edge(category_id, node_id):
                G.add_edge(
                    category_id,
                    node_id,
                    predicate="hasSubClass",
                    pheromone=1.0,
                )

        # 같은 카테고리의 다른 feature 노드와 sibling 연결
        # (개미가 같은 카테고리 내 특성 간 이동 가능)
        if category_id in G:
            for neighbor_id in list(G.successors(category_id)):
                if (
                    neighbor_id != node_id
                    and G.nodes.get(neighbor_id, {}).get("is_feature")
                ):
                    if not G.has_edge(node_id, neighbor_id):
                        G.add_edge(
                            node_id,
                            neighbor_id,
                            predicate="sibling",
                            pheromone=1.0,
                        )
                    if not G.has_edge(neighbor_id, node_id):
                        G.add_edge(
                            neighbor_id,
                            node_id,
                            predicate="sibling",
                            pheromone=1.0,
                        )

        self.mapped_features[original_name] = node_id
        self._label_to_node[semantic_label.lower()] = node_id
        self._label_to_node[feature_key.lower()] = node_id

        logger.debug(
            "Semantic-mapped '%s' -> %s (category=%s)",
            original_name,
            node_id,
            category_id,
        )

    def _register(self, feature_name: str, node_id: str) -> None:
        """매핑 등록 + 노드에 is_feature 속성 부여."""
        self.mapped_features[feature_name] = node_id
        self.graph.nodes[node_id]["is_feature"] = True
        self.graph.nodes[node_id]["feature_key"] = feature_name
        logger.debug("Mapped '%s' -> node '%s'", feature_name, node_id)


# ── CLI 실행 (데모) ───────────────────────────────────────────
if __name__ == "__main__":
    import sys
    sys.path.insert(0, ".")

    from src.aco.owl_graph_builder import OWLGraphBuilder

    logging.basicConfig(level=logging.INFO)

    owl_file = sys.argv[1] if len(sys.argv) > 1 else "ontology/DTO.xrdf"
    builder = OWLGraphBuilder(owl_file)
    G = builder.build()
    builder.print_summary()

    bridge = SMILESOntologyBridge(G, match_threshold=65)

    # 16 SMILES 기술자
    sample_features = [
        "molecular_weight", "logp", "tpsa", "num_hbd", "num_hba",
        "num_rotatable_bonds", "num_rings", "num_aromatic_rings",
        "num_atoms", "num_heavy_atoms", "fsp3", "num_heteroatoms",
        "num_carbons", "num_oxygens", "num_nitrogens", "num_halogens",
    ]

    mapping = bridge.auto_map(sample_features)
    unmapped = [f for f in sample_features if f not in mapping]
    if unmapped:
        bridge.create_feature_nodes(unmapped)

    bridge.print_mapping()
    print()
    stats = bridge.get_semantic_stats()
    print(f"Semantic stats: {stats}")
    print(f"Graph: {G.number_of_nodes()} nodes, {G.number_of_edges()} edges")
